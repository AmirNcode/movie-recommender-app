# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# TMDB_API_KEY: Required for fetching movie data (titles, year, genre, director,
# posters, etc.) from The Movie Database.
# Get your free API key at https://developer.themoviedb.org/
TMDB_API_KEY="MY_TMDB_API_KEY"

# Supabase public project URL
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"

# Supabase publishable key (safe for browser use)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."

# Supabase secret key (server-side only; never expose client-side)
SUPABASE_SECRET_KEY="sb_secret_..."

# Sentry DSN (server/edge runtimes) and its public counterpart (browser).
# Leave unset to disable error reporting (the SDK no-ops without a DSN).
SENTRY_DSN="https://YOUR_KEY@oYOUR_ORG.ingest.sentry.io/YOUR_PROJECT"
NEXT_PUBLIC_SENTRY_DSN="https://YOUR_KEY@oYOUR_ORG.ingest.sentry.io/YOUR_PROJECT"

# CRON_SECRET: Bearer token guarding the scheduled cron routes (S10 pool
# refresh; S9 weekly digest). Vercel Cron sends "Authorization: Bearer <value>"
# automatically when this env var is set on the project. Generate a long random
# string; requests without the matching bearer get 401.
CRON_SECRET="a-long-random-string"

# Canonical public origin, used as Next.js metadataBase so shareable /r/<id>
# Open Graph image URLs are absolute (S2). Optional: on Vercel it falls back to
# VERCEL_PROJECT_PRODUCTION_URL / VERCEL_URL, and to http://localhost:3000 in dev.
NEXT_PUBLIC_SITE_URL="https://your-domain.com"

# RESEND_API_KEY: sends the weekly digest email (S9). Get one at
# https://resend.com/api-keys
RESEND_API_KEY="re_your_api_key"

# RESEND_FROM_EMAIL: optional. Defaults to Resend's shared test sender
# (onboarding@resend.dev), which works with no setup. Switch to your own
# "Name <you@your-domain.com>" once the domain (D1) is verified with Resend.
RESEND_FROM_EMAIL="Filmmoo <onboarding@resend.dev>"
